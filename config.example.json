{
  "telegram_bot_token": "REPLACE_ME",
  "database_path": "./bot.sqlite3",
  "encryption_key": "REPLACE_ME_FERNET_KEY",
  "owner_user_id": 1234567890,
  "routing": {
    "require_bot_mention": false
  },
  "orchestrator_max_chain_auto_steps": 30,
  "llm": {
    "timeout_sec": 600
  },
  "formatting": {
    "allow_raw_html": true,
    "mode": "markdown"
  },
  "plugin_server": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 8015
  },
  "runtime_status": {
    "free_transition_delay_sec": 0,
    "skills_to_llm_delay_sec": 0
  },
  "skills": {
    "usage_prompt": "You can call skills by answering with a JSON object with strict structure. If you do not want to use skills, answer normally and your answer will be sent to the user. When calling a skill, answer with exactly this JSON object: {\"type\":\"skill_call\",\"skill_call\":{\"skill_id\":\"<skill_id>\",\"arguments\":{...}}}. Use only skill ids from skills.available.",
    "max_steps_per_request": 8,
    "followup_mode": "full"
  },
  "tools": {
    "enabled": true,
    "bash": {
      "enabled": true,
      "default_cwd": ".",
      "max_timeout_sec": 30,
      "max_output_chars": 12000,
      "safe_commands": [
        "pwd",
        "ls",
        "whoami",
        "date",
        "echo",
        "cat",
        "touch",
        "cp",
        "mkdir",
        "tee",
        "printf",
        "rg",
        "git",
        "python3"
      ],
      "allowed_workdirs": [
        "."
      ]
    }
  },
  "interface": {
    "active": "telegram",
    "modules_dir": "app.interfaces",
    "runtime_mode": "single"
  },
  "dispatch": {
    "mode": "single-instance",
    "is_runner": true
  },
  "migration": {
    "team": {
      "dual_read_enabled": false,
      "dual_write_enabled": false,
      "rollout_mode": "legacy"
    }
  }
}
